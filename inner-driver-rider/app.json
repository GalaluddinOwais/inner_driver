{
  "expo": {
    "name": "Inner Driver - Rider",
    "slug": "inner-driver-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is used to find nearby drivers and set your pickup point."
      }
    },
    "android": {
      "package": "com.innerdriver.rider",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDIEhSCFISnosSUmQ99VH_L1I9rq6HJeqE"
        }
      }
    },
    "web": { "favicon": "./assets/favicon.png" },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to find nearby drivers and set your pickup point."
        }
      ]
    ]
  }
}
