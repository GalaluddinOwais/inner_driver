{
  "expo": {
    "name": "Inner Driver - Driver",
    "slug": "inner-driver-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Your location is shared with riders so they can find nearby drivers while you are online."
      }
    },
    "android": {
      "package": "com.innerdriver.driver",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is shared with riders so they can find nearby drivers while you are online."
        }
      ]
    ]
  }
}
